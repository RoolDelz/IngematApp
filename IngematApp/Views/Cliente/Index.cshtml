@model IEnumerable<IngematApp.Models.Cliente>

@{
    ViewData["Title"] = "Directorio de Clientes";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-primary">Directorio de Clientes</h2>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Razón Social / Nombre</th>
                        <th>Doc.</th>
                        <th>N° Documento</th>
                        <th>Teléfono</th>
                        <th>Correo Electrónico</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.IdCliente</td>
                                <td class="align-middle fw-bold">@item.NomCliente</td>
                                <td class="align-middle text-muted">@item.Documento</td>
                                <td class="align-middle">@item.NDocumento</td>
                                <td class="align-middle">@item.TelefonoCliente</td>
                                <td class="align-middle">@item.CorreoCliente</td>
                                <td class="text-center align-middle">
                                    <a asp-action="Edit" asp-route-id="@item.IdCliente" class="btn btn-sm btn-warning fw-bold">
                                        Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">No se encontraron clientes registrados en el sistema.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>