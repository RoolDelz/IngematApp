@model IngematApp.Models.FacturaIndexViewModel
@{
    ViewData["Title"] = "Gestión de Facturas";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-2"><i class="bi bi-receipt-cutoff"></i> Gestión de Facturas</h2>
    <p class="text-muted mb-4">Administra el ciclo de vida de las facturas: define el método de pago, realiza y confirma el cobro.</p>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ============================================ *@
    @* SECCIÓN 1: FACTURAS PENDIENTES / GUARDADAS   *@
    @* ============================================ *@
    <div class="card shadow-sm border-warning mb-4">
        <div class="card-header bg-warning text-dark fw-bold">
            <i class="bi bi-hourglass-split"></i> Facturas Pendientes de Pago
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° Factura</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Proyecto</th>
                            <th>Precio Base</th>
                            <th>Precio Final</th>
                            <th>Método de Pago</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Pendientes.Any())
                        {
                            foreach (var f in Model.Pendientes)
                            {
                                <tr>
                                    <td class="align-middle fw-bold text-primary">@f.NumFactura</td>
                                    <td class="align-middle">@f.FechaFactura.ToString("dd/MM/yyyy")</td>
                                    <td class="align-middle fw-bold">@f.NomCliente</td>
                                    <td class="align-middle text-muted small">@f.Motivo</td>
                                    <td class="align-middle">S/ @f.PrecioBase.ToString("N2")</td>
                                    <td class="align-middle fw-bold text-success">S/ @f.PrecioFactura.ToString("N2")</td>
                                    <td class="align-middle" style="min-width: 180px;">
                                        <form asp-action="GuardarMetodoPago" method="post" class="d-flex align-items-center gap-1">
                                            <input type="hidden" name="IdFactura" value="@f.IdFactura" />
                                            <select name="MetodoPago" class="form-select form-select-sm" required
                                                    onchange="actualizarPrecio(this, @f.PrecioBase.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                                                <option value="" disabled selected="@(f.MetodoPago == "Sin definir")">-- Elegir --</option>
                                                <option value="Efectivo" selected="@(f.MetodoPago == "Efectivo")">Efectivo</option>
                                                <option value="Tarjeta Debito" selected="@(f.MetodoPago == "Tarjeta Debito")">Tarjeta Débito</option>
                                                <option value="Tarjeta Credito" selected="@(f.MetodoPago == "Tarjeta Credito")">Tarjeta Crédito (+3%)</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-primary" title="Guardar método de pago">
                                                <i class="bi bi-save"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="align-middle">
                                        @if (f.Estado == "Pendiente")
                                        {
                                            <span class="badge bg-secondary px-2 py-1">Pendiente</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info px-2 py-1">Guardado</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (f.Estado == "Guardado")
                                        {
                                            <form asp-action="Realizar" method="post" class="d-inline"
                                                  onsubmit="return confirm('¿Estás seguro de realizar esta factura? Una vez realizada no se podrá modificar.');">
                                                <input type="hidden" name="IdFactura" value="@f.IdFactura" />
                                                <button type="submit" class="btn btn-sm btn-success fw-bold">
                                                    <i class="bi bi-check2-square"></i> Realizar
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Seleccione método y guarde primero</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">No hay facturas pendientes.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ============================================ *@
    @* SECCIÓN 2: FACTURAS REALIZADAS               *@
    @* ============================================ *@
    <div class="card shadow-sm border-primary mb-4">
        <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-file-earmark-check"></i> Facturas Realizadas
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° Factura</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Proyecto</th>
                            <th>Método de Pago</th>
                            <th>Precio Final</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Realizadas.Any())
                        {
                            foreach (var f in Model.Realizadas)
                            {
                                <tr>
                                    <td class="align-middle fw-bold text-primary">@f.NumFactura</td>
                                    <td class="align-middle">@f.FechaFactura.ToString("dd/MM/yyyy")</td>
                                    <td class="align-middle fw-bold">@f.NomCliente</td>
                                    <td class="align-middle text-muted small">@f.Motivo</td>
                                    <td class="align-middle">
                                        <span class="badge bg-dark px-2 py-1">@f.MetodoPago</span>
                                    </td>
                                    <td class="align-middle fw-bold text-success">S/ @f.PrecioFactura.ToString("N2")</td>
                                    <td class="align-middle">
                                        <span class="badge bg-primary px-2 py-1">Realizada</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <a asp-action="Imprimir" asp-route-id="@f.IdFactura" target="_blank"
                                           class="btn btn-sm btn-outline-info fw-bold" title="Ver PDF">
                                            <i class="bi bi-printer"></i> PDF
                                        </a>
                                        <form asp-action="Pagar" method="post" class="d-inline"
                                              onsubmit="return confirm('¿Estás seguro de confirmar el pago de esta factura?');">
                                            <input type="hidden" name="IdFactura" value="@f.IdFactura" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold">
                                                <i class="bi bi-cash-coin"></i> Pago
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">No hay facturas realizadas pendientes de cobro.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ============================================ *@
    @* SECCIÓN 3: FACTURAS PAGADAS (Ocultas)        *@
    @* ============================================ *@
    <div class="text-center mb-3">
        <button class="btn btn-outline-success fw-bold px-4" type="button" data-bs-toggle="collapse" data-bs-target="#seccionPagadas">
            <i class="bi bi-eye"></i> Ver Facturas Pagadas (@Model.Pagadas.Count)
        </button>
    </div>

    <div class="collapse mb-4" id="seccionPagadas">
        <div class="card shadow-sm border-success">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-check-circle-fill"></i> Facturas Pagadas
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>N° Factura</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Proyecto</th>
                                <th>Método de Pago</th>
                                <th>Precio Final</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Pagadas.Any())
                            {
                                foreach (var f in Model.Pagadas)
                                {
                                    <tr>
                                        <td class="align-middle fw-bold text-success">@f.NumFactura</td>
                                        <td class="align-middle">@f.FechaFactura.ToString("dd/MM/yyyy")</td>
                                        <td class="align-middle fw-bold">@f.NomCliente</td>
                                        <td class="align-middle text-muted small">@f.Motivo</td>
                                        <td class="align-middle">
                                            <span class="badge bg-dark px-2 py-1">@f.MetodoPago</span>
                                        </td>
                                        <td class="align-middle fw-bold text-success">S/ @f.PrecioFactura.ToString("N2")</td>
                                        <td class="align-middle">
                                            <span class="badge bg-success px-2 py-1"><i class="bi bi-check-lg"></i> Pagado</span>
                                        </td>
                                        <td class="text-center align-middle">
                                            <a asp-action="Imprimir" asp-route-id="@f.IdFactura" target="_blank"
                                               class="btn btn-sm btn-outline-info fw-bold" title="Ver PDF">
                                                <i class="bi bi-printer"></i> PDF
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">No hay facturas pagadas aún.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function actualizarPrecio(select, precioBase) {
            var fila = select.closest('tr');
            var celdaPrecioFinal = fila.querySelectorAll('td')[5]; // 6ta columna = Precio Final
            var metodo = select.value;
            var precioFinal = metodo === 'Tarjeta Credito' ? precioBase * 1.03 : precioBase;
            celdaPrecioFinal.innerHTML = 'S/ ' + precioFinal.toFixed(2);

            if (metodo === 'Tarjeta Credito') {
                celdaPrecioFinal.classList.add('text-danger');
                celdaPrecioFinal.classList.remove('text-success');
            } else {
                celdaPrecioFinal.classList.add('text-success');
                celdaPrecioFinal.classList.remove('text-danger');
            }
        }
    </script>
}
