<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - INGEMAT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            body {
                background-color: #f4f6f9;
                margin: 0;
                overflow-x: hidden;
            }

            .wrapper {
                display: flex;
                width: 100%;
                height: 100vh;
            }

            .sidebar {
                width: 260px;
                background-color: #56b39a;
                color: white;
                display: flex;
                flex-direction: column;
                position: fixed;
                height: 100%;
                z-index: 1000;
            }

            .sidebar-header {
                padding: 20px;
                background-color: #56b39a;
                text-align: center;
                border-bottom: 1px solid #000000;
            }

            .sidebar .nav-link {
                color: #000000;
                padding: 12px 20px;
                font-weight: 500;
                transition: 0.3s;
                text-decoration: none;
                display: block;
            }

                .sidebar .nav-link:hover {
                    color: #fff;
                    background-color: #0d6efd;
                    border-radius: 0px 5px 5px 0px;
                }

            .content-area {
                flex-grow: 1;
                margin-left: 260px;
                display: flex;
                flex-direction: column;
            }

            .top-navbar {
                background-color: white;
                padding: 15px 25px;
                box-shadow: 0 2px 5px rgba(0,0,0,0.05);
                display: flex;
                justify-content: flex-end;
                align-items: center;
            }

            .main-content {
                padding: 30px;
                overflow-y: auto;
            }
    </style>
</head>
<body>

    <div class="wrapper">

        <nav class="sidebar">
            <div class="sidebar-header">
                <img src="~/images/logo.png" alt="Logo INGEMAT" class="img-fluid mb-2" style="max-height: 50px; display: block; margin: 0 auto;" />
                <h4 class="fw-bold text-white mb-0">INGEMAT</h4>
                
            </div>

            <ul class="nav flex-column mt-3">
                <li class="nav-item px-3 mb-2 text-uppercase text-secondary small fw-bold mt-2">Principal</li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-2 fs-5 align-middle"></i> Inicio
                    </a>
                </li>



                @if (User.IsInRole("Gerente") || User.IsInRole("Sub Gerente") || User.IsInRole("Ayudante Tecnico"))
                {
                    <li class="nav-item px-3 mb-2 text-uppercase text-secondary small fw-bold mt-4">Operaciones</li>

                    @if (User.IsInRole("Gerente") || User.IsInRole("Sub Gerente") || User.IsInRole("Ayudante Tecnico"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="OrdenTrabajo" asp-action="Index">
                                <i class="bi bi-clipboard-check me-2 fs-5 align-middle"></i> Ordenes de Trabajo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Proyecto" asp-action="Index">
                                <i class="bi bi-briefcase me-2 fs-5 align-middle"></i> Proyectos
                            </a>
                        </li>
                    }
                }

                @if (User.IsInRole("Gerente") || User.IsInRole("Sub Gerente") || User.IsInRole("Area de ventas"))
                {
                    <li class="nav-item px-3 mb-2 text-uppercase text-secondary small fw-bold mt-4">Comercial</li>
                        /*<li class="nav-item">
                            <a class="nav-link" asp-controller="Cliente" asp-action="Index">
                                <i class="bi bi-person-vcard me-2 fs-5 align-middle"></i> Directorio Clientes
                            </a>
                        </li>*/
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Proforma" asp-action="Index">
                                <i class="bi bi-file-earmark-text me-2 fs-5 align-middle"></i> Cotizaciones
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " asp-controller="OrdenServicio" asp-action="Index">
                                <i class="bi bi-tools me-2 fs-5 align-middle"></i> Ordenes de Servicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Factura" asp-action="Index">
                                <i class="bi bi-receipt me-2 fs-5 align-middle"></i> Facturas
                            </a>
                        </li>
                    }

                
                @if (User.IsInRole("Gerente") || User.IsInRole("Sub Gerente"))
                {
                    <li class="nav-item px-3 mb-2 text-uppercase text-secondary small fw-bold mt-4">Configuración</li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Empleado" asp-action="Index">
                            <i class="bi bi-people me-2 fs-5 align-middle"></i> Control de Personal
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Categoria" asp-action="Index">
                            <i class="bi bi-file-earmark-medical me-2 fs-5 align-middle"></i> Categorías
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Formato" asp-action="Index">
                            <i class="bi bi-file-earmark-medical me-2 fs-5 align-middle"></i> Formatos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="SubFormato" asp-action="Index">
                            <i class="bi bi-ui-checks-grid me-2 fs-5 align-middle"></i> Subformatos
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <div class="content-area">

            <header class="top-navbar">
                <div class="d-flex align-items-center">
                    <div class="text-end me-3">
                        <span class="fw-bold text-dark d-block">@User.Identity.Name</span>
                        <span class="text-muted small text-uppercase">
                            @(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Invitado")
                        </span>
                    </div>
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger btn-sm fw-bold px-3">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </a>
                </div>
            </header>

            <main class="main-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>