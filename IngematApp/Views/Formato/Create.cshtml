@model IngematApp.Models.Formato

@{
    ViewData["Title"] = "Crear Formato";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0 fw-bold">Nuevo Formato</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="IdCategoria" class="form-label fw-bold">Categoría Padre</label>
                            <select asp-for="IdCategoria" class="form-select" required>
                                <option value="">-- Seleccione una Categoría --</option>
                                @foreach (var cat in ViewBag.Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.NomCategoria</option>
                                }
                            </select>
                            <span asp-validation-for="IdCategoria" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NomFormato" class="form-label fw-bold">Nombre del Formato</label>
                            <input asp-for="NomFormato" class="form-control" placeholder="Ej: Ensayo de Penetración" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PrecioFormato" class="form-label fw-bold">Precio del Formato (S/)</label>
                            <input asp-for="PrecioFormato" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success fw-bold">Guardar Formato</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>