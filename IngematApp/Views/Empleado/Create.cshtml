@model IngematApp.Models.Empleado
@{ ViewData["Title"] = "Registrar Personal"; }

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0 fw-bold">Nuevo Personal Corporativo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="NombreEmpleado" class="form-label fw-bold">Nombre Completo</label>
                            <input asp-for="NombreEmpleado" class="form-control" required />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Dni" class="form-label fw-bold">DNI (8 dígitos)</label>
                                <input asp-for="Dni" class="form-control" maxlength="8" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TelefonoEmpleado" class="form-label fw-bold">Teléfono</label>
                                <input asp-for="TelefonoEmpleado" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CorreoEmpleado" class="form-label fw-bold">Correo Electrónico (Usuario)</label>
                            <input asp-for="CorreoEmpleado" type="email" class="form-control" placeholder="ejemplo@ingemat.com" required />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Cargo" class="form-label fw-bold">Perfil del Sistema</label>
                            <select asp-for="Cargo" class="form-select border-primary" required>
                                <option value="">-- Seleccione Perfil --</option>
                                @if (User.IsInRole("Gerente"))
                                {
                                    <option value="Sub Gerente">Sub Gerente</option>
                                }
                                <option value="Area de ventas">Area de ventas</option>
                                <option value="Ayudante Tecnico">Ayudante Tecnico</option>
                            </select>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success fw-bold">Registrar Acceso</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>