@model IngematApp.Models.Categoria

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0 fw-bold">Editar Categoría</h4>
                </div>
                <div class="card-body">

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="IdCategoria" />

                        <div class="mb-3">
                            <label asp-for="NomCategoria" class="form-label fw-bold">Nombre de la Categoría</label>
                            <input asp-for="NomCategoria" class="form-control" required />
                            <span asp-validation-for="NomCategoria" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-warning fw-bold">Actualizar</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}