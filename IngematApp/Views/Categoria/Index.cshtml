@model IEnumerable<IngematApp.Models.Categoria>

@{
    ViewData["Title"] = "Listar Categorías";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-primary">Listado de Categorías</h2>

    <div class="mb-3 d-flex justify-content-between">
        <a asp-action="Create" class="btn btn-success fw-bold">
            + Crear Nueva Categoría
        </a>

        <form asp-controller="Categoria" asp-action="ListarCategoriasPorNombre" method="get" class="d-flex">
            <label class="me-2 align-self-center fw-bold">Buscar:</label>
            <input type="text" name="pNombre" class="form-control me-2" placeholder="Nombre de categoría..." />
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre de la Categoría</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.IdCategoria</td>
                                <td class="align-middle">@item.NomCategoria</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-warning fw-bold">Editar</a>

                                    <a asp-action="Delete" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-danger fw-bold" onclick="return confirm('¿Estás seguro de eliminar la categoría: @item.NomCategoria?');">Eliminar</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4">No se encontraron categorías registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>