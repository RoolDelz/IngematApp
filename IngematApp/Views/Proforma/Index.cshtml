@model IEnumerable<IngematApp.Models.ProformaListado>

@{
    ViewData["Title"] = "Historial de Cotizaciones";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-primary">Gestión de Proformas (Cotizaciones)</h2>

    <div class="mb-3 d-flex justify-content-between">
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">
            + Generar Nueva Cotización
        </a>

        <form asp-controller="Proforma" asp-action="ListarProformasPorCliente" method="get" class="d-flex">
    <input type="text" name="pNombre" class="form-control me-2" placeholder="Buscar cliente..." />
    <button type="submit" class="btn btn-primary">Buscar</button>
</form>
    </div>

    <div class="card shadow-sm border-primary">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>N° Proforma</th>
                        <th>Fecha Emisión</th>
                        <th>Cliente / Razón Social</th>
                        <th>Motivo del Servicio</th>
                        <th>Sub Total</th>
                        <th>Precio Final (+IGV)</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold text-primary">PROF-@item.IdProforma.ToString("D4")</td>
                                <td class="align-middle">@item.FechaP.ToString("dd/MM/yyyy")</td>
                                <td class="align-middle fw-bold">@item.NomCliente</td>
                                <td class="align-middle">@item.Motivo</td>
                                <td class="align-middle">S/ @item.Total.ToString("0.00")</td>
                                <td class="align-middle fw-bold text-success">S/ @item.PrecioFinal.ToString("0.00")</td>
                                
                                <td class="text-center align-middle">
                                    <a asp-action="Imprimir" asp-route-id="@item.IdProforma" target="_blank" class="btn btn-sm btn-info text-white fw-bold">
                                        <i class="bi bi-printer"></i> Imprimir
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">No se han generado cotizaciones aún.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>