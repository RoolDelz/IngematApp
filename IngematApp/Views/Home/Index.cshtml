@{
    ViewData["Title"] = "Inicio";

    // Extraemos la información del usuario logueado de la memoria del sistema
    var nombre = User.Identity.Name ?? "Usuario no identificado";
    var cargo = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Sin Rol";
    var correo = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "No registrado";
    var dni = User.FindFirst("Dni")?.Value ?? "No registrado";
}

<div class="container-fluid mt-2">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-top border-4 border-primary">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-person-circle text-secondary mb-3" style="font-size: 5rem;"></i>
                    <h3 class="fw-bold text-dark">@nombre</h3>
                    <span class="badge bg-primary fs-6 mb-4 px-3 py-2 text-uppercase">@cargo</span>

                    <ul class="list-group list-group-flush text-start mt-3">
                        <li class="list-group-item px-0">
                            <strong><i class="bi bi-credit-card-2-front me-2"></i> DNI / Identificación:</strong> @dni
                        </li>
                        <li class="list-group-item px-0">
                            <strong><i class="bi bi-envelope-at me-2"></i> Correo Electrónico:</strong> @correo
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            @if (cargo == "Gerente")
            {
                <div class="alert alert-success h-100 shadow-sm border-0">
                    <h4 class="fw-bold"><i class="bi bi-shield-lock me-2"></i> Acceso Total</h4>
                    <p>Como Gerente de INGEMAT, posees permisos administrativos absolutos. Puedes gestionar el directorio de clientes, aprobar órdenes de servicio, administrar al personal de la empresa y configurar los formatos de los estudios de suelos.</p>
                </div>
            }
            else if (cargo == "Area de ventas")
            {
                <div class="alert alert-info h-100 shadow-sm border-0">
                    <h4 class="fw-bold"><i class="bi bi-graph-up me-2"></i> Panel Comercial</h4>
                    <p>Módulo de ventas activo. Tienes autorización para generar nuevas cotizaciones a los clientes y emitir solicitudes de Órdenes de Servicio para el área operativa. No tienes permisos para aprobar transacciones ni alterar las tarifas del sistema.</p>
                </div>
            }
            else if (cargo == "Ayudante Tecnico")
            {
                <div class="alert alert-warning h-100 shadow-sm border-0">
                    <h4 class="fw-bold"><i class="bi bi-gear me-2"></i> Panel Operativo</h4>
                    <p>Módulo técnico activo. Tu acceso está enfocado en la ejecución en campo y laboratorio. Revisa la pestaña de "Órdenes de Trabajo" en el menú izquierdo para visualizar tus proyectos asignados y subir los reportes correspondientes.</p>
                </div>
            }
        </div>
    </div>
</div>