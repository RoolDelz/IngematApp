@model IngematApp.Models.OrdenServicioViewModel
@{
    ViewData["Title"] = "Generar Orden de Servicio";
}

<div class="container mt-4">
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0 fw-bold">Paso 2: Generar Orden y Registrar Empresa</h4>
        </div>
        <div class="card-body">
            <form asp-action="GuardarOS" method="post">
                <input type="hidden" asp-for="IdProforma" />

                <div class="row">
                    <div class="col-md-5 border-end pe-4">
                        <h5 class="text-secondary fw-bold mb-3"><i class="bi bi-file-earmark-text"></i> Cotización Vinculada</h5>

                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Cliente Original</label>
                            <input class="form-control bg-light" value="@Model.NomCliente" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Proyecto / Motivo</label>
                            <textarea class="form-control bg-light" rows="3" readonly>@Model.Motivo</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Importe Acordado</label>
                            <input class="form-control bg-light text-success fw-bold" value="S/ @Model.PrecioFinal.ToString("0.00")" readonly />
                        </div>
                    </div>

                    <div class="col-md-7 ps-4">
                        <h5 class="text-secondary fw-bold mb-3"><i class="bi bi-building"></i> Datos de la Empresa Solicitante</h5>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="NomEmpresa" class="form-label fw-bold">Razón Social</label>
                                <input asp-for="NomEmpresa" class="form-control" placeholder="Ej: Constructora XYZ S.A.C." required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Ruc" class="form-label fw-bold">RUC</label>
                                <input asp-for="Ruc" class="form-control" maxlength="11" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TelefonoEmpresa" class="form-label fw-bold">Teléfono de Contacto</label>
                                <input asp-for="TelefonoEmpresa" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CorreoEmpresa" class="form-label fw-bold">Correo Corporativo</label>
                                <input asp-for="CorreoEmpresa" type="email" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DireccionEmpresa" class="form-label fw-bold">Dirección Fiscal / Operativa</label>
                            <input asp-for="DireccionEmpresa" class="form-control" />
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="SeleccionarProforma" class="btn btn-secondary">Cambiar Cotización</a>
                    <button type="submit" class="btn btn-success fw-bold px-4">Guardar Orden y Registrar Empresa</button>
                </div>
            </form>
        </div>
    </div>
</div>