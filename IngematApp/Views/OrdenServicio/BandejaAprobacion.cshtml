@model IEnumerable<IngematApp.Models.OrdenServicioListado>
@{
    ViewData["Title"] = "Aprobaciones Pendientes";
}

<div class="container mt-4">
    <h2 class="fw-bold text-warning mb-2">🛡️ Panel de Control Gerencial</h2>
    <p class="text-muted mb-4">Evaluación y aprobación de Órdenes de Servicio operativas. Al aprobar un elemento, el sistema creará automáticamente el Proyecto de ejecución enlazado.</p>

    <div class="card shadow-sm border-warning">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-warning">
                    <tr>
                        <th>N° OS</th>
                        <th>Fecha Registro</th>
                        <th>Cliente</th>
                        <th>Proyecto Estimado</th>
                        <th>Empresa Asignada</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">OS-@item.IdOS.ToString("D4")</td>
                                <td class="align-middle">@item.FechaOS.ToString("dd/MM/yyyy")</td>
                                <td class="align-middle fw-bold">@item.NomCliente</td>
                                <td class="align-middle text-muted">@item.Motivo</td>
                                <td class="align-middle">@item.NomEmpresa</td>
                                <td class="text-center align-middle">
                                    <form asp-action="ProcessAprobacion" method="post" onsubmit="return confirm('¿Confirmar aprobación de esta Orden y abrir el Proyecto automáticamente?');">
                                        <input type="hidden" name="idOS" value="@item.IdOS" />
                                        <button type="submit" class="btn btn-sm btn-success fw-bold">
                                            ✔ Aprobar y Crear Proyecto
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">No existen órdenes de servicio pendientes de revisión gerencial.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3"><a asp-action="Index" class="btn btn-secondary">Volver al Historial General</a></div>
</div>